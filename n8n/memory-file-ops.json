    {
      "parameters": {
        "jsCode": "// Auth validation for all webhooks\nconst headerSecret = $inputs.first().json.headers?.['x-api-secret'] || $inputs.first().json.header?.['x-api-secret'] || '';\nconst expectedSecret = $env.API_SECRET || 'change-me-in-env';\n\nif (headerSecret !== expectedSecret) {\n  throw new Error('Unauthorized: invalid API secret');\n}\n\nreturn $input.all();"
      },
