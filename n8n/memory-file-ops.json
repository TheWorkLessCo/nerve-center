    {
      "parameters": {
        "jsCode": "// Path sanitization: strip '..' and '/' from agentId\nconst body = $input.first().json.body || {};\nconst rawAgentId = body.agentId || '';\n\n// Remove path traversal attempts\nconst sanitizedAgentId = rawAgentId\n  .replace(/\\.\\./g, '')\n  .replace(/\\//g, '')\n  .replace(/\\\\/g, '')\n  .trim();\n\nif (!sanitizedAgentId) {\n  throw new Error('agentId is required');\n}\n\nif (rawAgentId !== sanitizedAgentId) {\n  throw new Error('Invalid agentId: path traversal detected');\n}\n\nreturn [{ json: { ...body, agentId: sanitizedAgentId } }];"
      },
      "id": "sanitize-agent-id",
      "name": "Sanitize agentId (Path Traversal)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [450, 550]
    },
    {
      "parameters": {
        "jsCode": "// Path sanitization for write\nconst body = $input.first().json.body || {};\nconst rawAgentId = body.agentId || '';\nconst rawContent = body.content || '';\n\n// Remove path traversal attempts from agentId\nconst sanitizedAgentId = rawAgentId\n  .replace(/\\.\\./g, '')\n  .replace(/\\//g, '')\n  .replace(/\\\\/g, '')\n  .trim();\n\nif (!sanitizedAgentId) {\n  throw new Error('agentId is required');\n}\n\nif (rawAgentId !== sanitizedAgentId) {\n  throw new Error('Invalid agentId: path traversal detected');\n}\n\n// Escape single quotes in content for shell safety\nconst safeContent = rawContent.replace(/'/g, \"'\\\\''\");\n\nreturn [{ json: { agentId: sanitizedAgentId, content: safeContent, rawContent: rawContent } }];"
      },
      "id": "sanitize-write",
      "name": "Sanitize Write Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [450, 800]
    },
    {
      "parameters": {
        "jsCode": "// Parse ls output for GET /nerve-memory-list\nconst agentOutput = $input.item.json.output || '';\nconst systemOutput = $input.item(1).json.output || '';\n\nconst parseFiles = (output) => {\n  return output\n    .split('\\n')\n    .filter(line => line.trim())\n    .map(line => line.replace(/.*\\//, '')); // strip path\n};\n\nreturn [{ json: {\n  agents: parseFiles(agentOutput),\n  system: parseFiles(systemOutput)\n}}];"
      },
      "id": "format-list-response",
      "name": "Format List Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [850, 300]
    },
    {
      "parameters": {
        "jsCode": "// Format read response\nconst readOutput = $input.item.json.output || '';\nconst mtimeOutput = $input.item(1).json.output || '';\n\nif (readOutput === 'FILE_NOT_FOUND') {\n  return [{ json: { error: 'Memory file not found', lastModified: null } }];\n}\n\nreturn [{ json: {\n  content: readOutput,\n  lastModified: mtimeOutput !== 'UNKNOWN' ? mtimeOutput : null\n}}];"
      },
      "id": "format-read-response",
      "name": "Format Read Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [850, 600]
    },
    {
      "parameters": {
        "jsCode": "// Format write response\nconst writeOutput = $input.item.json.output || '';\n\nif (!writeOutput.includes('WRITE_SUCCESS')) {\n  return [{ json: { success: false, error: 'Write failed' } }];\n}\n\nreturn [{ json: {\n  success: true,\n  timestamp: new Date().toISOString()\n}}];"
      },
      "id": "format-write-response",
      "name": "Format Write Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [850, 800]
    },
